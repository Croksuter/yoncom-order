# Next.js migration workspace
# apps/next renders without env, but DB-backed Next Route Handlers need the
# Cloudflare D1 credentials below.
# Run it with:
#   pnpm dev:next

# Cloudflare D1 credentials
# Used by packages/db/drizzle.config.ts and by apps/next read-only API routes.
# CLOUDFLARE_ACCOUNT_ID is the Cloudflare account id from the dashboard URL,
# not your login email.
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_DATABASE_ID=replace-with-cloudflare-d1-database-id
CLOUDFLARE_D1_TOKEN=replace-with-cloudflare-d1-api-token

# Cloudflare Worker runtime bindings
# These are NOT read from .env by the current Hono API. They must be configured
# in apps/api/wrangler.jsonc or the Cloudflare dashboard.
#
# D1 binding name expected by apps/api: DB
# R2 binding name expected by apps/api: R2_BUCKET
# D1 database name used by existing scripts: yoncom-order-db
# R2 bucket name used by existing config: yoncom-order
