# Next.js workspace
# apps/next renders without env, but DB-backed Next Route Handlers and seed
# scripts need the Cloudflare D1 credentials below.
# Run it with:
#   pnpm dev

# Cloudflare D1 credentials
# Used by packages/db/drizzle.config.ts and by apps/next API routes.
# CLOUDFLARE_ACCOUNT_ID is the Cloudflare account id from the dashboard URL,
# not your login email.
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CLOUDFLARE_DATABASE_ID=replace-with-cloudflare-d1-database-id
CLOUDFLARE_D1_TOKEN=replace-with-cloudflare-d1-api-token

# Realtime Worker notification bridge
REALTIME_NOTIFY_URL=https://replace-with-worker-host/internal/realtime/notify
REALTIME_NOTIFY_SECRET=replace-with-shared-realtime-secret

# Structured verification trace logs.
# Development enables trace logs by default; set these explicitly for production-like runs.
YONCOM_TRACE=1
NEXT_PUBLIC_YONCOM_TRACE=1
