KB_LOGIN_URL=https://obank.kbstar.com/quics?page=C055068&QSL=F
KB_POLL_INTERVAL_SECONDS=10
KB_DOM_WAIT_SECONDS=20
KB_STATE_FILE=.state/sent-transactions.json
KB_DRY_RUN=true
KB_LOG_DIR=.logs
KB_SAVE_DOM=true

# Optional Chrome profile reuse. Default keeps Chrome data inside this app dir.
KB_CHROME_USER_DATA_DIR=.chrome-profile
KB_CHROME_PROFILE_DIRECTORY=Default
KB_CHROME_DETACH=true
KB_CHROME_HEADLESS=false
KB_CHROME_REMOTE_DEBUGGING_PORT=9222
KB_CHROME_DEBUGGER_ADDRESS=

# Production worker target. Use http://localhost:3000 only for local debugging.
YONCOM_APP_BASE_URL=https://yoncom-order.croksuter.com
YONCOM_ADMIN_EMAIL=
YONCOM_ADMIN_PASSWORD=

# Alternative to YONCOM_ADMIN_EMAIL/PASSWORD. Use only for local debugging.
YONCOM_SESSION_COOKIE=
YONCOM_CSRF_TOKEN=
